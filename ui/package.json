{
    "name": "personal-tracker-ui",
    "private": true,
    "version": "0.1.7",
    "repository": {
        "type": "git",
        "url": "https://github.com/MSF42/personal-tracker.git"
    },
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite --host",
        "build": "run-p type-check \"build-only {@}\"",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "eslint . --fix",
        "format": "prettier --write src/",
        "verify": "npm run format && npm run lint && npm run type-check",
        "preview": "vite preview",
        "electron:dev": "npm run dev",
        "electron:start": "electron .",
        "electron:build": "electron-builder --mac",
        "electron:build:win": "electron-builder --win",
        "electron:build:linux": "electron-builder --linux",
        "build-macos": "bash scripts/build-macos.sh",
        "test": "vitest run",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.3",
        "@primevue/auto-import-resolver": "^4.5.4",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.18",
        "chart.js": "^4.5.1",
        "dompurify": "^3.3.3",
        "electron-updater": "^6.8.3",
        "highlight.js": "^11.11.1",
        "marked": "^17.0.3",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4",
        "sql.js": "^1.14.0",
        "tailwindcss": "^4.1.18",
        "tailwindcss-primeui": "^0.6.1",
        "vue": "^3.5.25",
        "vue-router": "^5.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/dompurify": "^3.0.5",
        "@types/node": "^24.10.1",
        "@types/sql.js": "^1.4.9",
        "@vitejs/plugin-vue": "^6.0.2",
        "@vitest/ui": "^4.1.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/tsconfig": "^0.8.1",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-vue": "^10.7.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "~5.9.3",
        "unplugin-vue-components": "^31.0.0",
        "vite": "^7.3.1",
        "vite-plugin-vue-devtools": "^8.0.6",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.2.4"
    },
    "build": {
        "appId": "com.stevefurches.personaltracker",
        "productName": "Personal Tracker",
        "publish": {
            "provider": "github",
            "owner": "MSF42",
            "repo": "personal-tracker"
        },
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**",
            "electron/**",
            "!electron/binaries"
        ],
        "icon": "electron/icons/icon.png",
        "mac": {
            "target": "dmg",
            "icon": "electron/icons/icon.icns",
            "artifactName": "PersonalTracker-${version}-mac.dmg",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "electron/entitlements.mac.plist",
            "entitlementsInherit": "electron/entitlements.mac.plist",
            "notarize": true,
            "extraResources": [
                {
                    "from": "electron/binaries/personal-tracker-api",
                    "to": "personal-tracker-api"
                }
            ]
        },
        "win": {
            "target": "nsis",
            "artifactName": "PersonalTracker-${version}-win-setup.exe",
            "extraResources": [
                {
                    "from": "electron/binaries/personal-tracker-api.exe",
                    "to": "personal-tracker-api.exe"
                }
            ]
        },
        "linux": {
            "target": "AppImage",
            "category": "Utility",
            "artifactName": "PersonalTracker-${version}-linux.AppImage",
            "extraResources": [
                {
                    "from": "electron/binaries/personal-tracker-api",
                    "to": "personal-tracker-api"
                }
            ]
        }
    }
}
